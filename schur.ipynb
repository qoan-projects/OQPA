    "from qiskit.transpiler import PassManager\n",
    "from qiskit.transpiler.passes import BasisTranslator\n",
    "from qiskit.circuit.equivalence_library import SessionEquivalenceLibrary as sel\n",
    "from qiskit.quantum_info.synthesis import UnitarySynthesis\n",
    "\n",
    "# Create a Quantum Circuit with the Unitary Matrix\n",
    "num_qubits = int(np.log2(unitary_matrix.shape[0]))\n",
    "qc = QuantumCircuit(num_qubits)\n",
    "qc.unitary(unitary_matrix, list(range(num_qubits)), label='U')\n",
    "\n",
    "# Print the initial circuit\n",
    "print(\"\\nInitial Circuit:\")\n",
    "print(qc)\n",
    "\n",
    "# Create a custom basis with u3 and an arbitrary two-qubit gate\n",
    "basis_gates = ['u3', 'unitary']\n",
    "\n",
    "# Define a custom equivalence library\n",
    "custom_basis = sel()\n",
    "\n",
    "# Create a pass manager with the BasisTranslator pass to unroll gates to the specified basis\n",
    "passmanager = PassManager([\n",
    "    BasisTranslator(custom_basis, basis_gates),\n",
    "    UnitarySynthesis(custom_basis)\n",
    "])\n",
    "\n",
    "# Transpile the circuit\n",
    "transpiled_qc = passmanager.run(qc)\n",
    "\n",
    "# Print the transpiled circuit\n",
    "print(\"\\nTranspiled Circuit:\")\n",
    "print(transpiled_qc)\n",
    "\n",
    "# Obtain the gate count\n",
    "gate_count = transpiled_qc.count_ops()\n",
    "print(\"\\nGate Count:\")\n",
    "print(gate_count)\n",
    "\n",
    "# Obtain the circuit depth\n",
    "circuit_depth = transpiled_qc.depth()\n",
    "print(\"\\nCircuit Depth:\")\n",
    "print(circuit_depth)\n"
   ]
