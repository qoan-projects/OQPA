    "import numpy as np\n",
    "from qiskit import QuantumCircuit, transpile\n",
    "from qiskit.visualization import array_to_latex\n",
    "from qiskit_aer import AerSimulator\n",
    "\n",
    "# Create a quantum circuit\n",
    "qc = transpiled_qc\n",
    "qc = qc_new\n",
    "\n",
    "# Use the AerSimulator to get the unitary\n",
    "simulator = AerSimulator(method='unitary')\n",
    "qc.save_unitary()\n",
    "\n",
    "# Compile and run the circuit on the unitary simulator\n",
    "compiled_circuit = transpile(qc, simulator)\n",
    "result = simulator.run(compiled_circuit).result()\n",
    "\n",
    "# Get the unitary matrix\n",
    "unitary = result.get_unitary(compiled_circuit)\n",
    "print(\"Unitary matrix:\")\n",
    "print(unitary)\n",
    "\n",
    "# Optional: Display the unitary matrix in a more readable format\n",
    "array_to_latex(unitary, prefix=\"\\\\text{Unitary matrix: }\")\n"
   ]
