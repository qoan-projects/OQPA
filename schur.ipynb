    "# Define a random 4x4 unitary matrix (2 qubits)\n",
    "# Create a quantum circuit with 2 qubits\n",
    "qc_BU = QuantumCircuit(2)\n",
    "qc_SU = QuantumCircuit(3)\n",
    "\n",
    "# Convert the unitary matrix to a gate and add to the circuit\n",
    "qc_BU.unitary(BU, [0,1], label='U')\n",
    "qc_SU.unitary(SU, [0,1], label='U')\n",
    "\n",
    "# Transpile the circuit to decompose the unitary gate\n",
    "transpiled_qc = transpile(qc_BU, basis_gates=['u3', 'cz'], optimization_level=3)\n",
    "print(transpiled_qc)\n",
    "\n",
    "\n",
    "extract = transpiled_qc.data[1:2]\n",
    "print(extract)\n",
    "qc_new = QuantumCircuit(transpiled_qc.num_qubits)\n",
    "for gate in extract:\n",
    "    qc_new.append(gate[0], gate[1], gate[2] if len(gate) > 2 else [])\n",
    "print(qc_new)"
   ]
  },
