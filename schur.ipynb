    "from qiskit.circuit.library import U3Gate, CZGate, CCXGate\n",
    "# Example of manually adding CCZ gates\n",
    "num_qubits=5\n",
    "custom_qc = QuantumCircuit(num_qubits)\n",
    "custom_qc.append(UnitaryGate(unitary_matrix), list(range(num_qubits)))\n",
    "\n",
    "# Manually add CCZ gate at some positions (example only)\n",
    "custom_qc.append(CCXGate(), [0, 1, 2])\n",
    "custom_qc.append(U3Gate(np.pi, 0, np.pi), [0])\n",
    "custom_qc.append(CZGate(), [0, 1])\n",
    "\n",
    "# Print the custom circuit with CCZ gates\n",
    "print(\"\\nCustom Circuit with CCZ Gates:\")\n",
    "print(custom_qc)"
